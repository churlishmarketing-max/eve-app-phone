# Copy to .env and fill in. NEVER commit .env.

# Anthropic API key (Brandon's console). For local dev the Agent SDK can also
# use this machine's Claude Code login if this is unset.
ANTHROPIC_API_KEY=

# Bearer token the app/curl must send on every request. Generate a long random one.
EVE_BRAIN_TOKEN=change-me

# Model for EVE's brain. Brandon's call 2026-07-15: start on Sonnet 5 for cost;
# claude-opus-4-8 is the upgrade lever if her judgment needs it.
EVE_MODEL=claude-sonnet-5

PORT=8787

# Firebase Admin (FCM push). Two routes — use ONE:
#  (A) Downloaded service-account key: set the absolute path to the JSON from
#      Firebase console > Project settings > Service accounts. Keep it OUTSIDE the repo.
#  (B) Keyless via gcloud (use when org policy blocks key downloads):
#      run `gcloud auth application-default login`, leave the path below unset, and
#      set FIREBASE_PROJECT_ID so the brain knows which project to send to.
# Leave both unset until Firebase is set up — push stays disabled, chat still works.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=eve-project-9090

# Brandon's timezone — quiet hours (21:30–06:30) and the 07:00 morning brief
# compute in this zone regardless of the server's own timezone.
EVE_TZ=America/Chicago

# --- Phase 2: memory spine ---
# Supabase (existing project — pre-flight checklist). Settings > API in the dashboard.
# Run brain/sql/001_memory_spine.sql in the SQL Editor once before first use.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Voyage AI embeddings for semantic recall (voyage-4; docs.voyageai.com — free tier
# covers this use for years). OPTIONAL: without it recall falls back to Postgres
# full-text search; run POST /job {"job":"embed_backfill"} after adding it later.
VOYAGE_API_KEY=

# --- Phase 3: her hands (see RUNBOOK_phase3_keys.md for the exact clicks) ---
# ALL optional — each tool reports "not connected" honestly until its key lands.

# Google (Gmail read/search/draft + Calendar). Mint once:
#   node scripts/google-auth.mjs <CLIENT_ID> <CLIENT_SECRET>
# Consent screen MUST be published to production (Testing = 7-day token death).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Voice: Deepgram STT in, ElevenLabs TTS out. VOICE_ID optional (defaults to
# the premade "Rachel" until EVE's imprint is chosen; GET /voice/voices lists options).
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Slack read (user token xoxp — User Token Scopes, not Bot).
SLACK_USER_TOKEN=

# Notion internal integration (ntn_...) — share pages with the integration or she sees nothing.
NOTION_TOKEN=

# Stripe RESTRICTED read-only key (rk_...) — never the full secret key.
STRIPE_KEY=
