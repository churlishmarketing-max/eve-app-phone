# Copy to .env.local for dev. These ship inside the APK (single-user, sideloaded —
# 02_ARCHITECTURE §7: the app carries only the brain URL + its token + Firebase config).

# Where the brain lives. Dev: localhost. APK on your phone: the hosted brain URL,
# or your PC's LAN IP (e.g. http://192.168.1.20:8787) while testing over Wi-Fi.
VITE_BRAIN_URL=http://localhost:8787

# Must match EVE_BRAIN_TOKEN in brain/.env.
VITE_BRAIN_TOKEN=
